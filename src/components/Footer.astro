---
import { FOOTER_LINKS, BRAND_NAME, SOCIAL_LINKS } from '../config';
import { resolvePath } from '../utils/navigation';

interface Props {
  showBrandLink?: boolean;
}

const { showBrandLink = false } = Astro.props;
---

<footer class="bg-[#000000] dark:bg-[#09090b] pt-16 pb-8 transition-colors">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-[minmax(280px,1.35fr)_repeat(2,minmax(140px,1fr))] lg:gap-10 mb-12">
      <div>
        <a href={resolvePath('/')} class="flex items-center gap-2 mb-4">
          <img src={resolvePath('/images/logo-smartmoov-v.svg')} alt="SmartMooV" class="h-10 w-auto" />
        </a>
        <p class="text-slate-300 text-base font-bold uppercase tracking-wide mb-4">
          Movemos marcas, <span class="text-primary-400">ligamos pessoas.</span>
        </p>
        <p class="text-slate-400 text-sm">
          Projeto-piloto na Figueira da Foz.
        </p>
      </div>

      {FOOTER_LINKS.map(group => (
        <div>
          <h3 class="font-semibold text-white mb-4 text-base">{group.title}</h3>
          <ul class="space-y-3">
            {group.links.map(link => (
              <li>
                <a href={resolvePath(link.href)} class="text-base text-slate-400 hover:text-primary-400 transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="border-t border-slate-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-500">
        &copy; {new Date().getFullYear()} {BRAND_NAME}.
      </p>

      {showBrandLink && (
        <p class="text-base">
          <a href={resolvePath('/brands/')} class="text-primary-400 hover:text-primary-300 transition-colors font-medium">
            Também és marca? Conhece o SmartMooV para empresas →
          </a>
        </p>
      )}
      
      {SOCIAL_LINKS.instagram && (
        <div class="flex gap-4 text-slate-500">
          <a href={SOCIAL_LINKS.instagram} class="hover:text-primary-400 transition-colors" target="_blank" rel="noopener noreferrer">
            <span class="sr-only">Instagram</span>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      )}
    </div>
  </div>
</footer>
