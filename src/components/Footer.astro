---
import { FOOTER_LINKS, BRAND_NAME, SOCIAL_LINKS } from '../config';
import { resolvePath } from '../utils/navigation';

interface Props {
  showBrandLink?: boolean;
  showDriverLink?: boolean;
}

const { showBrandLink = false, showDriverLink = false } = Astro.props;
---

<footer class="bg-[#000000] dark:bg-[#09090b] pt-16 pb-8 transition-colors">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-[minmax(280px,1.35fr)_repeat(2,minmax(140px,1fr))] lg:gap-10 mb-12">
      <div>
        <div class="flex items-start gap-4 mb-4">
          <a href={resolvePath('/')} class="flex-shrink-0">
            <img src={resolvePath('/images/logo-smartmoov-r.svg')} alt="SmartMooV" class="h-12 w-auto" />
          </a>
          <p class="text-slate-300 text-base font-bold uppercase tracking-wide leading-snug">
            Movemos marcas,<br /><span class="text-primary-400">ligamos pessoas.</span>
          </p>
        </div>
        <p class="text-slate-400 text-sm">
          Projeto-piloto na Figueira da Foz.
        </p>
      </div>

      {FOOTER_LINKS.map(group => (
        <div>
          <h3 class="font-semibold text-white mb-4 text-base">{group.title}</h3>
          <ul class="space-y-3">
            {group.links.map(link => (
              <li>
                <a href={resolvePath(link.href)} class="text-base text-slate-400 hover:text-primary-400 transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="border-t border-slate-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-500">
        &copy; {new Date().getFullYear()} {BRAND_NAME}.
      </p>

      {showDriverLink && (
        <p class="text-base">
          <a href={resolvePath('/drivers/')} class="text-primary-400 hover:text-primary-300 transition-colors font-medium">
            Também é condutor? Conhece o SmartMooV para condutores →
          </a>
        </p>
      )}

      {showBrandLink && (
        <p class="text-base">
          <a href={resolvePath('/')} class="text-primary-400 hover:text-primary-300 transition-colors font-medium">
            Também és marca? Conhece o SmartMooV para empresas →
          </a>
        </p>
      )}
    </div>
  </div>
</footer>
