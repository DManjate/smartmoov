---
import Button from './Button.astro';
import Badge from './Badge.astro';
import { resolvePath } from '../utils/navigation';

interface Props {
  heading: string;
  punchline: string;
  subtitle: string;
  heroCarUrl?: string;
}

const {
  heading = 'OS KILÓMETROS QUE FAZES,',
  punchline = 'PODEM RENDER MAIS.',
  subtitle = 'Transforma o teu carro numa fonte de rendimento extra.',
  heroCarUrl,
} = Astro.props;
---

<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-white dark:bg-[#09090b]">
    <div class="absolute top-0 right-0 -translate-y-1/4 translate-x-1/4 w-[600px] h-[400px] bg-primary-400/20 dark:bg-primary-900/30 rounded-full blur-[80px] opacity-60 mix-blend-multiply dark:mix-blend-screen"></div>
    <div class="absolute bottom-0 left-0 translate-y-1/4 -translate-x-1/4 w-[500px] h-[350px] bg-primary-400/10 dark:bg-primary-900/20 rounded-full blur-[80px] opacity-50 mix-blend-multiply dark:mix-blend-screen"></div>
  </div>
  
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center reveal-on-scroll">
    <div class="flex justify-center mb-8">
      <Badge variant="primary" class="px-4 py-1.5 text-sm border border-primary-200 dark:border-primary-800 backdrop-blur-md bg-white/50 dark:bg-primary-900/50">
        Projeto-piloto na Figueira da Foz
      </Badge>
    </div>
    
    <h1 class="text-6xl sm:text-7xl lg:text-8xl font-heading font-extrabold tracking-tight mb-8 max-w-5xl mx-auto leading-[1.1]">
      <span class="text-slate-900 dark:text-white">{heading}</span>
      <br class="sm:hidden" />
      <span class="text-primary-600 dark:text-primary-400">{punchline}</span>
    </h1>
    
    <p class="text-xl sm:text-2xl text-slate-600 dark:text-slate-400 mb-12 max-w-3xl mx-auto font-sans leading-relaxed">
      {subtitle}
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-20">
      <Button href="#form-section" variant="primary" size="lg" class="w-full sm:w-auto text-lg px-8 py-4 shadow-xl shadow-primary-500/20">
        QUERO SABER MAIS →
      </Button>
    </div>

    {heroCarUrl && (
      <div class="relative mx-auto max-w-6xl reveal-on-scroll" style="transition-delay: 200ms;">
        <div class="aspect-[16/9] rounded-3xl overflow-hidden relative group hover-glow shadow-2xl">
          <img src={heroCarUrl} alt="Carro com publicidade SmartMooV a circular na cidade" class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-[1.02]" loading="eager" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent pointer-events-none"></div>
        </div>
        <div class="absolute -bottom-12 -right-12 -z-10 w-96 h-96 bg-primary-500/30 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-[100px]"></div>
      </div>
    )}

    {!heroCarUrl && (
      <div class="relative mx-auto max-w-6xl reveal-on-scroll" style="transition-delay: 200ms;">
        <div class="aspect-[16/9] rounded-3xl bg-slate-200 dark:bg-slate-800 flex items-center justify-center overflow-hidden shadow-2xl">
          <div class="text-slate-400 dark:text-slate-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.2c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
          </div>
        </div>
      </div>
    )}
  </div>
</section>
