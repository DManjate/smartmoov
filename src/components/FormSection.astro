---
interface Props {
  formUrl: string;
  fallbackUrl: string;
  sectionTitle?: string;
  sectionDescription?: string;
}

const {
  formUrl,
  fallbackUrl,
  sectionTitle = 'INSCREVE-TE',
  sectionDescription = 'Preenche o formulário abaixo e entraremos em contacto.',
} = Astro.props;
---

<section id="form-section" class="py-32 bg-[#F2F2F3] dark:bg-[#0c0c0f] relative overflow-hidden">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-2xl relative z-10">
    <div class="text-center mb-16 reveal-on-scroll">
      <h2 class="text-4xl md:text-5xl font-heading font-extrabold text-slate-900 dark:text-white mb-6">
        {sectionTitle}
      </h2>
      <p class="text-xl text-slate-600 dark:text-slate-400 font-sans">
        {sectionDescription}
      </p>
    </div>

    <div class="glass-panel rounded-3xl overflow-hidden p-2 reveal-on-scroll" style="transition-delay: 100ms;">
      <iframe
        src={formUrl}
        width="100%"
        height="800"
        class="w-full min-h-[800px] border-0 rounded-2xl"
        title="Formulário de inscrição SmartMooV"
        loading="lazy"
        sandbox="allow-scripts allow-forms allow-same-origin"
      >
      </iframe>
    </div>

    <p class="text-center mt-6 text-sm text-slate-500 dark:text-slate-400 reveal-on-scroll" style="transition-delay: 200ms;">
      O formulário não carregou?{' '}
      <a href={fallbackUrl} target="_blank" rel="noopener noreferrer" class="text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 underline font-medium transition-colors">
        Clica aqui para abrir numa nova página →
      </a>
    </p>

    <p class="text-center mt-8 text-xs text-slate-400 dark:text-slate-500 reveal-on-scroll" style="transition-delay: 300ms;">
      Todos os dados protegidos. Nunca partilhados sem autorização.
    </p>
  </div>
</section>
